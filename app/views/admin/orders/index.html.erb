<h1 class="font-display text-2xl font-semibold text-[#211A14] mb-1">Orders</h1>
<div class="h-0.5 w-10 bg-[#A8362B] mb-6"></div>

<%= form_with url: admin_orders_path, method: :get do |f| %>
  <div class="flex flex-wrap gap-3 mb-6">
    <%= f.text_field :email, value: params[:email], placeholder: "Search by email or name",
          class: "w-64 bg-white/60 rounded-sm border border-[#d8c9a3] px-3 py-2 text-sm text-[#211A14] focus:outline-none focus:border-[#A8362B] focus:ring-2 focus:ring-[#A8362B]/20 transition-colors" %>
    <%= f.select :status,
          options_for_select([["All statuses", ""], ["Paid", "paid"], ["Pending", "pending"]], params[:status]),
          {},
          class: "bg-white/60 rounded-sm border border-[#d8c9a3] px-3 py-2 text-sm text-[#211A14] focus:outline-none focus:border-[#A8362B] focus:ring-2 focus:ring-[#A8362B]/20 transition-colors" %>
    <%= f.submit "Filter",
          class: "bg-[#A8362B] text-[#F6EFDD] hover:bg-[#8f2c22] rounded-md px-4 py-2 text-sm font-medium cursor-pointer transition-colors" %>
    <%= link_to "Reset", admin_orders_path, class: "px-4 py-2 text-sm text-[#6b5f4f] hover:text-[#211A14]" %>
  </div>
<% end %>

<div class="bg-[#FFFEFB] border border-[#E7DFC9] rounded-md overflow-hidden">
  <table class="w-full text-sm">
    <thead class="text-[#9C8C72] border-b border-[#EFE7D2]">
      <tr>
        <th class="text-left font-medium px-5 py-3">Customer</th>
        <th class="text-left font-medium px-5 py-3">Product</th>
        <th class="text-left font-medium px-5 py-3">Amount</th>
        <th class="text-left font-medium px-5 py-3">Location</th>
        <th class="text-left font-medium px-5 py-3">Status</th>
        <th class="text-left font-medium px-5 py-3">Email</th>
        <th class="text-left font-medium px-5 py-3">Date</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-[#EFE7D2]">
      <% @orders.each do |order| %>
        <tr class="hover:bg-[#FAF6EC]">
          <td class="px-5 py-3">
            <%= link_to admin_order_path(order), class: "text-[#A8362B] hover:text-[#8f2c22] font-medium" do %>
              <%= order.name.presence || order.email.presence || "—" %>
            <% end %>
            <div class="text-xs text-[#9C8C72]"><%= order.email %></div>
          </td>
          <td class="px-5 py-3"><%= order.product&.title %></td>
          <td class="px-5 py-3"><%= number_to_currency(order.amount_in_rupees, unit: "₹", precision: 0) %></td>
          <td class="px-5 py-3 text-[#6b5f4f]"><%= [order.city, order.country].compact_blank.join(", ").presence || "—" %></td>
          <td class="px-5 py-3">
            <% status_class = case order.status
                              when "paid"     then "bg-[#E5EEE0] text-[#2F5233] border-[#2F5233]/25"
                              when "refunded" then "bg-[#EFE7D2] text-[#6b5f4f] border-[#9C8C72]/25"
                              else                 "bg-[#F5E9D0] text-[#8a6d1f] border-[#8a6d1f]/25"
                              end %>
            <span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium border <%= status_class %>">
              <%= order.status %>
            </span>
          </td>
          <td class="px-5 py-3">
            <% if order.status != "paid" %>
              <span class="text-[#9C8C72]">—</span>
            <% elsif order.download_email_sent_at %>
              <span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium border bg-[#E5EEE0] text-[#2F5233] border-[#2F5233]/25"
                    title="Sent <%= order.download_email_sent_at.strftime('%d %b %Y, %H:%M') %>">Sent</span>
            <% else %>
              <span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium border bg-[#FBF0EC] text-[#7a1f17] border-[#A8362B]">Not sent</span>
            <% end %>
          </td>
          <td class="px-5 py-3 text-[#6b5f4f]"><%= order.created_at.strftime("%d %b %Y, %H:%M") %></td>
        </tr>
      <% end %>

      <% if @orders.empty? %>
        <tr><td colspan="7" class="px-5 py-6 text-center text-[#9C8C72]">No orders match.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
