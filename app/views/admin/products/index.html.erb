<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Worksheets</h1>
  <%= link_to "+ Add worksheet", admin_new_product_path,
        class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm font-medium hover:bg-gray-800" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-gray-500">
      <tr>
        <th class="text-left font-medium px-5 py-3">Title</th>
        <th class="text-left font-medium px-5 py-3">Price</th>
        <th class="text-left font-medium px-5 py-3">Active</th>
        <th class="text-left font-medium px-5 py-3">PDF</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @products.each do |product| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 font-medium text-gray-900"><%= product.title %></td>
          <td class="px-5 py-3"><%= number_to_currency(product.price_in_paise.to_i / 100.0, unit: "₹", precision: 0) %></td>
          <td class="px-5 py-3">
            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium
              <%= product.active? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600" %>">
              <%= product.active? ? "Active" : "Inactive" %>
            </span>
          </td>
          <td class="px-5 py-3"><%= product.worksheet_pdf.attached? ? "✓" : "—" %></td>
          <td class="px-5 py-3 text-right whitespace-nowrap">
            <%= link_to "Edit", admin_edit_product_path(product),
                  class: "text-indigo-600 hover:text-indigo-800 mr-3" %>
            <%= button_to "Delete", admin_product_path(product), method: :delete,
                  form: { class: "inline", data: { turbo_confirm: "Delete this worksheet?" } },
                  class: "text-red-600 hover:text-red-800" %>
          </td>
        </tr>
      <% end %>

      <% if @products.empty? %>
        <tr><td colspan="5" class="px-5 py-6 text-center text-gray-400">No worksheets yet.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
