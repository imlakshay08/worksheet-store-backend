<%= form_with model: [:admin, product], local: true,
      html: { class: "bg-white rounded-xl border border-gray-200 p-6 max-w-2xl space-y-5" } do |form| %>

  <% if product.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc list-inside">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title,
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:ring-1 focus:ring-gray-500" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 4,
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:ring-1 focus:ring-gray-500" %>
  </div>

  <div>
    <%= form.label :slug, "Slug (used in the buy link, e.g. french-articles-worksheet)",
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :slug,
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:ring-1 focus:ring-gray-500" %>
  </div>

  <div>
    <%= form.label :price_in_paise, "Price in paise (e.g. 7900 for ₹79)",
          class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.number_field :price_in_paise,
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:ring-1 focus:ring-gray-500" %>
  </div>

  <div class="flex items-center gap-2">
    <%= form.check_box :active, class: "rounded border-gray-300" %>
    <%= form.label :active, "Active (visible for sale)?", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div>
    <%= form.label :worksheet_pdf, "Worksheet PDF", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.file_field :worksheet_pdf, accept: "application/pdf", class: "block text-sm" %>
    <% if product.worksheet_pdf.attached? %>
      <p class="text-xs text-gray-500 mt-1">Current file: <%= product.worksheet_pdf.filename %></p>
    <% end %>
  </div>

  <div>
    <%= form.submit "Save",
          class: "bg-gray-900 text-white rounded-md px-5 py-2 text-sm font-medium hover:bg-gray-800 cursor-pointer" %>
  </div>
<% end %>
